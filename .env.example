# Server
PORT=4000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@db:5432/course_registration

# JWT
JWT_ACCESS_SECRET=replace_access_secret_here
JWT_REFRESH_SECRET=replace_refresh_secret_here
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Supabase
SUPABASE_URL=https://your-supabase-url.supabase.co
SUPABASE_SERVICE_KEY=replace_service_key_here
