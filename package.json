{
  "name": "student-course-registration-system",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Enterprise-grade student course registration system built with Node.js, Express, Prisma, and Supabase PostgreSQL.",
  "main": "backend/server/index.js",
  "scripts": {
    "dev": "nodemon backend/server/index.js",
    "start": "node backend/server/index.js",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{js,json,md,yaml,yml}\"",
    "test": "jest --runInBand",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csurf": "^1.2.2",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "swagger-ui-express": "^5.0.1",
    "xss": "^1.0.15",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-node": "^11.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "prisma": "^6.19.3",
    "supertest": "^7.1.4"
  },
  "engines": {
    "node": "20.x"
  }
}
